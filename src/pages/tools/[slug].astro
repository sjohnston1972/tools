---
import Base from "../../layouts/Base.astro";
import BrutalNav from "../../components/BrutalNav.astro";
import BrutalFooter from "../../components/BrutalFooter.astro";
import ToolMock from "../../components/ToolMock.astro";
import ScreenshotGallery from "../../components/ScreenshotGallery.tsx";
import { TOOLS, TOOL_BY_SLUG } from "../../data/tools";

export const prerender = true;

export function getStaticPaths() {
  return TOOLS.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tool = TOOL_BY_SLUG[slug as keyof typeof TOOL_BY_SLUG];
if (!tool) {
  return Astro.redirect("/");
}
// next three tools, wrapping around, for the footer nav
const idx = TOOLS.findIndex((t) => t.slug === tool.slug);
const peers = [1, 2, 3].map((o) => TOOLS[(idx + o) % TOOLS.length]);
---

<Base title={`${tool.name} · Steven Johnston`} description={tool.blurb}>
  <BrutalNav current="work" />

  {/* hero */}
  <section class="px-5 pt-12 md:px-10 md:pt-16">
    <a href="/#work" class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted transition-colors hover:text-ink">← Work</a>
    <div class="mt-8 flex items-center gap-2.5">
      <span class="inline-block h-1.5 w-1.5" style={{ background: tool.color }}></span>
      <span class="brutal-eyebrow uppercase">№ {tool.n} · {tool.tag} · {tool.year}</span>
    </div>
    <h1 class="brutal-h1 mt-4 text-[44px] sm:text-[64px] md:text-[84px]">
      {tool.name}
    </h1>
    <p class="mt-6 mb-12 max-w-[720px] text-[17px] font-medium leading-relaxed text-muted [text-wrap:pretty] md:text-[18px]">
      {tool.blurb}
    </p>
  </section>

  {/* hero preview */}
  <section class="px-5 pb-12 md:px-10">
    <div class="overflow-hidden border border-line bg-cream-2">
      <div class="h-[3px]" style={{ background: tool.color }}></div>
      <div class="relative aspect-[16/9]">
        <div class="absolute inset-5 overflow-hidden border border-line md:inset-8">
          <ToolMock slug={tool.slug} accent={tool.color} />
        </div>
      </div>
    </div>
    <div class="mt-2.5 font-mono text-[10.5px] uppercase tracking-[0.14em] text-muted">
      Fig. 01 · stylised interface preview
    </div>
  </section>

  {/* meta strip */}
  <section class="grid grid-cols-2 border-y border-line md:grid-cols-4">
    {[
      ["Context", tool.client],
      ["Duration", tool.duration],
      ["Role", tool.role],
      ["Status", tool.status],
    ].map(([k, v], i) => (
      <div
        class={`px-5 py-5 md:px-6 ${i % 2 === 0 ? "border-r border-line" : "md:border-r md:border-line"} ${i < 2 ? "border-b border-line md:border-b-0" : ""} ${i === 3 ? "md:!border-r-0" : ""}`}
      >
        <div class="brutal-eyebrow uppercase">{k}</div>
        <div class="mt-2 text-[14px] font-medium">{v}</div>
      </div>
    ))}
  </section>

  {/* problem */}
  <section class="grid gap-6 px-5 py-14 md:grid-cols-[240px_1fr] md:gap-10 md:px-10 md:py-20">
    <h2 class="text-2xl font-bold tracking-tight">The problem</h2>
    <p class="max-w-[680px] text-[16px] font-medium leading-relaxed [text-wrap:pretty] md:text-[17px]">
      {tool.problem}
    </p>
  </section>

  {/* approach */}
  <section class="border-t border-line px-5 py-14 md:px-10 md:py-20">
    <div class="grid gap-6 md:grid-cols-[240px_1fr] md:gap-10">
      <h2 class="text-2xl font-bold tracking-tight">The approach</h2>
      <div class="flex max-w-[680px] flex-col">
        {tool.approach.map((step, i) => (
          <div
            class={`grid grid-cols-[44px_1fr] items-start gap-4 py-5 ${
              i > 0 ? "border-t border-line" : "pt-0"
            }`}
          >
            <div class="font-mono text-[13px] font-medium" style={{ color: tool.color }}>
              {String(i + 1).padStart(2, "0")}
            </div>
            <p class="text-[15px] leading-relaxed text-ink [text-wrap:pretty]">
              {step}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* screenshots — uploaded via admin mode, stored in R2, served from
      /api/img/<slug>/. Compact strip + lightbox; renders nothing when empty
      and not in admin mode. */}
  <ScreenshotGallery slug={tool.slug} name={tool.name} accent={tool.color} client:idle />


  {/* outcome */}
  <section class="bg-ink px-5 py-16 text-cream md:px-10 md:py-20">
    <h2 class="text-2xl font-bold tracking-tight">
      Outcome <span style={{ color: tool.color }}>↓</span>
    </h2>
    <div class="mt-10 grid grid-cols-1 border border-cream/15 sm:grid-cols-3">
      {tool.outcome.map(([metric, value, delta], i) => (
        <div
          class={`px-6 py-8 ${
            i < tool.outcome.length - 1 ? "border-b border-cream/15 sm:border-b-0 sm:border-r" : ""
          }`}
        >
          <div class="font-mono text-[10.5px] font-medium uppercase tracking-[0.18em]" style={{ color: tool.color }}>
            {metric}
          </div>
          <div class="mt-4 text-[30px] font-bold leading-none tracking-tight md:text-[36px]">
            {value}
          </div>
          {delta && delta !== "—" && delta !== "–" && (
            <div class="mt-2.5 text-[13px] font-medium text-cream/55">{delta}</div>
          )}
        </div>
      ))}
    </div>
    <div class="mt-12 max-w-[760px] border-l-2 pl-5" style={{ borderColor: tool.color }}>
      <div class="font-mono text-[10.5px] font-medium uppercase tracking-[0.18em] text-cream/55">Design note</div>
      <p class="mt-3 text-[18px] font-medium leading-relaxed [text-wrap:pretty] md:text-[20px]">
        {tool.quote}
      </p>
    </div>
  </section>

  {/* stack */}
  <section class="grid items-start gap-6 px-5 py-14 md:grid-cols-[240px_1fr] md:gap-10 md:px-10">
    <h2 class="text-2xl font-bold tracking-tight">Built with</h2>
    <div class="flex max-w-[680px] flex-wrap gap-2">
      {tool.stack.map((s) => (
        <span class="brutal-pill">{s}</span>
      ))}
    </div>
  </section>

  {/* links */}
  <section class="border-t border-line px-5 py-12 md:px-10">
    <div class="flex flex-wrap gap-3">
      {tool.github ? (
        <a
          href={tool.github}
          target="_blank"
          rel="noopener"
          class="brutal-link-cta"
        >GitHub ↗</a>
      ) : (
        <span
          class="cursor-default select-none border border-dashed border-line px-4 py-2.5 text-xs font-medium tracking-[0.04em] text-muted"
        >GitHub · coming soon</span>
      )}
    </div>
    {!tool.github && (
      <p class="mt-4 max-w-[560px] text-[13.5px] font-medium leading-relaxed text-muted">
        The repos are private while they get tidied for release. Ask and I'll happily walk through the code, the architecture, or a live demo.
      </p>
    )}
  </section>

  {/* peer projects */}
  <section class="border-t border-line px-5 py-14 md:px-10">
    <h2 class="text-2xl font-bold tracking-tight">More tools</h2>
    <div class="mt-6">
      {peers.map((p) => (
        <a
          href={`/tools/${p.slug}`}
          class="tile-lift group grid grid-cols-[44px_1fr_24px] items-baseline gap-4 border-b border-line px-2 py-5 md:grid-cols-[64px_240px_1fr_24px] md:items-center md:px-4"
        >
          <span class="font-mono text-[11px] text-muted">{p.n}</span>
          <span class="flex items-center gap-2.5">
            <span class="hidden h-1.5 w-1.5 shrink-0 md:inline-block" style={{ background: p.color }}></span>
            <span class="text-[16px] font-semibold tracking-tight">{p.name}</span>
          </span>
          <span class="col-start-2 row-start-2 text-[13.5px] leading-snug text-muted md:col-start-3 md:row-start-1 md:pr-8">
            {p.tag}
          </span>
          <span class="row-arrow col-start-3 row-start-1 text-right text-[15px] text-muted group-hover:text-ink md:col-start-4">→</span>
        </a>
      ))}
    </div>
  </section>

  {/* floating back button — fades in once the inline hero link scrolls away */}
  <a
    id="floating-back"
    href="/#work"
    class="fixed left-5 top-[72px] z-30 flex translate-y-[-8px] items-center gap-2 border border-line bg-cream/90 px-3 py-2 text-[12px] font-semibold tracking-[0.04em] text-ink opacity-0 shadow-soft-sm backdrop-blur-sm transition-all duration-200 hover:border-ink md:left-8"
    aria-label="Back to all tools"
  >
    ← Back
  </a>

  <BrutalFooter />

  <script is:inline>
    (() => {
      const btn = document.getElementById("floating-back");
      if (!btn) return;
      const onScroll = () => {
        const show = window.scrollY > 220;
        btn.style.opacity = show ? "1" : "0";
        btn.style.transform = show ? "translateY(0)" : "translateY(-8px)";
        btn.style.pointerEvents = show ? "auto" : "none";
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    })();
  </script>
</Base>
