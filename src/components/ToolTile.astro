---
import type { Tool } from "../data/tools";
import ToolMock from "./ToolMock.astro";
import TileThumb from "./TileThumb.tsx";

interface Props {
  tool: Tool;
  big?: boolean;
}
const { tool } = Astro.props;
---

<a
  href={`/tools/${tool.slug}`}
  class="group flex h-full flex-col border border-line bg-cream transition-all duration-150 hover:border-ink hover:shadow-soft"
>
  <div class="flex items-center justify-between border-b border-line px-4 py-2.5">
    <span class="font-mono text-[10.5px] text-muted">№ {tool.n}</span>
    <span class="font-mono text-[10.5px] uppercase tracking-[0.12em] text-muted">{tool.status}</span>
  </div>

  <div class="border-b border-line bg-cream-2 p-3.5">
    <div class="relative aspect-[4/3] overflow-hidden border border-line">
      <TileThumb slug={tool.slug} name={tool.name} client:idle>
        <ToolMock slug={tool.slug} accent={tool.color} />
      </TileThumb>
    </div>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="brutal-eyebrow uppercase" style={{ color: tool.color }}>
      {tool.tag}
    </div>
    <div class="mt-1.5 text-[22px] font-bold tracking-tight">{tool.name}</div>
    <p class="mt-2 flex-1 text-[13.5px] leading-relaxed text-muted [text-wrap:pretty]">
      {tool.blurb}
    </p>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {tool.stack.slice(0, 4).map((s) => (
        <span class="brutal-tag">{s}</span>
      ))}
      {tool.stack.length > 4 && (
        <span class="brutal-tag opacity-60">+{tool.stack.length - 4}</span>
      )}
    </div>

    <div class="mt-5 flex items-center justify-between border-t border-line pt-3.5 text-[13px] font-semibold">
      <span>Read the story</span>
      <span class="row-arrow text-muted group-hover:text-ink">→</span>
    </div>
  </div>
</a>
