---
interface Props {
  accent?: string;
}
const year = new Date().getFullYear();
---

<section
  id="about"
  class="scroll-mt-20 grid items-end gap-10 border-t border-line px-5 py-16 md:grid-cols-[2fr_1fr] md:px-10 md:py-20"
>
  <div>
    <div class="brutal-eyebrow mb-4 uppercase">Get in touch</div>
    <a
      href="mailto:Stevie.Johnston@gmail.com"
      class="block break-all text-3xl font-bold tracking-tight transition-colors hover:text-accent sm:text-4xl md:break-normal md:text-6xl"
    >
      stevie.johnston@gmail.com
    </a>
  </div>
  <div class="text-[14px] font-medium leading-relaxed text-muted">
    <div>Glasgow, Scotland</div>
    <div>UTC+0 / UTC+1</div>
    <div class="mt-4 flex flex-col gap-1">
      <a href="https://clydeford.net" class="transition-colors hover:text-ink" target="_blank" rel="noopener">
        clydeford.net ↗
      </a>
      <a
        href="https://www.linkedin.com/in/steven-johnston-474a5333/"
        class="transition-colors hover:text-ink"
        target="_blank"
        rel="noopener">LinkedIn ↗</a>
      <a href="https://github.com/sjohnston1972" class="transition-colors hover:text-ink" target="_blank" rel="noopener"
        >GitHub ↗</a>
    </div>
  </div>
</section>

<footer
  class="flex flex-col items-start justify-between gap-2 border-t border-line px-5 py-5 font-mono text-[11px] text-muted sm:flex-row sm:items-center md:px-10"
>
  <span>© {year} Steven Johnston · built by hand, and by Claude</span>
  <span>tools.clydeford.net</span>
</footer>
